# This file is a template only.
# The application does NOT require a Groq API key to be set here.
# Each user supplies their own Groq API key at login, and it is kept
# only in the server-side session for the duration of their browser session.
# It is never written to the database, to this file, or to any log.

# Optional: override the default SQLite database location
DATABASE_URL=sqlite:///./recipes.db

# Optional: secret key used to sign the session cookie
SESSION_SECRET_KEY=change-this-to-a-random-secret-in-production
